{
  "name": "@alipeople/sendon-sdk-typescript",
  "version": "1.0.5",
  "description": "OpenAPI client for @alipeople/sendon-sdk-typescript",
  "author": "teho@alipeople.kr",
  "keywords": [
    "axios",
    "typescript",
    "openapi-client",
    "openapi-generator",
    "@alipeople/sendon-sdk-typescript"
  ],
  "license": "MIT",
  "main": "./dist/wrapper/wrapper.js",
  "types": "./dist/wrapper/wrapper.d.ts",
  "module": "./dist/esm/wrapper/wrapper.js",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "clean": "rimraf --glob 'src/**/*.{js,d.ts,js.map}' 'dist'",
    "preprepare": "yarn install",
    "prepare": "yarn build",
    "test": "jest"
  },
  "dependencies": {
    "axios": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "@types/jest": "^29.5.12",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "typescript": "^5.1.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "unplugin-swc": "^1.5.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
